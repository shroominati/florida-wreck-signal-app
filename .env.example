PORT=8787
RPC_URL=https://api.devnet.solana.com
ESCROW_WALLET=YOUR_ESCROW_WALLET
ADMIN_KEY=CHANGE_ME

# Optional: managed Postgres. If not set, JSON file mode is used.
# DATABASE_URL=postgres://user:pass@host:5432/db

# Require approved creator verification before market publish.
REQUIRE_VERIFIED_CREATOR=true

# Optional for frontend static deploy
# REVEAL_API_BASE=https://your-render-api.onrender.com

# Telegram -> local Codex bridge
# 1) Create a bot with @BotFather and paste the token below.
# 2) Message your bot once, then get your chat/user ids from:
#    https://api.telegram.org/bot<token>/getUpdates
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_CHAT_ID=1603197641
TELEGRAM_ALLOWED_USER_ID=1603197641
TELEGRAM_WORKDIR=/Users/alfredmunoz/clawbot
TELEGRAM_ENABLE_SHELL=false
TELEGRAM_BOT_LOG_PATH=~/.spicywhite/logs/telegram-codex-bot.log
TELEGRAM_COMMAND_TIMEOUT_MS=900000
CODEX_DEFAULT_MODE=safe
CODEX_SAFE_SANDBOX=workspace-write
CODEX_SAFE_BYPASS=false
# Optional "fast" mode used by /codex_mode fast
# CODEX_FAST_SANDBOX=danger-full-access
# CODEX_FAST_BYPASS=false
